<DefaultWindow xmlns="https://spacestation14.io"
               Title="{Loc 'disease-diagnoser-title'}"
               MinSize="300 260">
    <BoxContainer Orientation="Vertical" Margin="8" HorizontalExpand="True">
        <Label Name="StatusLabel" Text="{Loc 'disease-diagnoser-no-sample'}" />
        <BoxContainer Orientation="Horizontal" Margin="0 6 0 4">
            <Button Name="ScanButton" Access="Public" Text="{Loc 'disease-diagnoser-scan-button'}" Disabled="True" HorizontalExpand="True" />
            <Button Name="EjectButton" Access="Public" Text="{Loc 'disease-diagnoser-eject-button'}" Margin="4 0 0 0" />
        </BoxContainer>
        <ProgressBar Name="ScanProgress" MaxValue="1" Value="0" MinHeight="14" />
        <PanelContainer StyleClasses="LowDivider" Margin="0 6" />
        <Label Name="VirusNameLabel" Visible="False" />
        <BoxContainer Name="SymptomsContainer" Orientation="Vertical" Margin="4 0 0 0" />
        <Label Name="TransmissionLabel" Visible="False" Margin="0 4 0 0" />
        <Label Name="UnreadableLabel" StyleClasses="LabelSubText" Visible="False" Margin="0 4 0 0" />
        <PanelContainer StyleClasses="LowDivider" Margin="0 6" />
        <Label Name="BufferLabel" />
        <BoxContainer Orientation="Horizontal" Margin="0 4 0 0">
            <Button Name="TransferButton" Access="Public" Text="{Loc 'disease-diagnoser-transfer-button'}" Disabled="True" HorizontalExpand="True" />
            <Button Name="CopyButton" Access="Public" Text="{Loc 'disease-diagnoser-copy-button'}" Disabled="True" Margin="4 0 0 0" HorizontalExpand="True" />
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
