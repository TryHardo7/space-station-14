<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
               xmlns:pathology="clr-namespace:Content.Client.SS220.Pathology"
               Title=""
               MinSize="340 400">
    <PanelContainer>
        <PanelContainer.PanelOverride>
            <graphics:StyleBoxFlat BackgroundColor="#1E1E22" />
        </PanelContainer.PanelOverride>
        <BoxContainer Orientation="Vertical" Margin="6">
            <PanelContainer>
                <PanelContainer.PanelOverride>
                    <graphics:StyleBoxFlat BackgroundColor="#141418" />
                </PanelContainer.PanelOverride>
                <BoxContainer Orientation="Horizontal" Margin="8 5" VerticalAlignment="Center">
                    <TextureRect TexturePath="/Textures/Interface/Nano/ntlogo.svg.png"
                                 Stretch="KeepAspectCentered" SetSize="22 22" Margin="0 0 8 0" />
                    <Label Text="{Loc 'vaccinator-header'}" StyleClasses="LabelHeading" FontColorOverride="#A88B5E" />
                    <Control HorizontalExpand="True" />
                    <Label Name="StationLabel" StyleClasses="LabelSubText" FontColorOverride="#7E7E88" />
                </BoxContainer>
            </PanelContainer>

            <Label Name="StatusLabel" Text="{Loc 'vaccinator-no-sample'}" Margin="2 8 0 4" />

            <pathology:DnaProgressBar Name="ScanProgress" MinHeight="40" Margin="0 0 0 6" />

            <BoxContainer Orientation="Horizontal" Margin="0 0 0 2">
                <Button Name="ScanButton" Access="Public" Text="{Loc 'vaccinator-scan-button'}" Disabled="True" HorizontalExpand="True" />
                <Button Name="EjectButton" Access="Public" Text="{Loc 'vaccinator-eject-button'}" Margin="4 0 0 0" />
            </BoxContainer>

            <PanelContainer StyleClasses="LowDivider" Margin="0 6" />
            <BoxContainer Name="ResultsContainer" Orientation="Vertical" />
            <PanelContainer StyleClasses="LowDivider" Margin="0 6" />

            <Label Name="BufferLabel" />
            <BoxContainer Orientation="Horizontal" Margin="0 4 0 0">
                <Button Name="TransferButton" Access="Public" Text="{Loc 'vaccinator-transfer-button'}" Disabled="True" HorizontalExpand="True" />
                <Button Name="CreateVaccineButton" Access="Public" Text="{Loc 'vaccinator-create-button'}" Disabled="True" Margin="4 0 0 0" HorizontalExpand="True" />
            </BoxContainer>
            <Button Name="PrintButton" Access="Public" Text="{Loc 'vaccinator-print-button'}" Disabled="True" Margin="0 4 0 0" HorizontalExpand="True" />

            <Label Text="{Loc 'pathology-console-os'}" StyleClasses="LabelSubText" FontColorOverride="#45454D" HorizontalAlignment="Left" Margin="2 8 0 0" />
        </BoxContainer>
    </PanelContainer>
</DefaultWindow>
