<DefaultWindow xmlns="https://spacestation14.io"
               Title="{Loc 'vaccinator-title'}"
               MinSize="300 300">
    <BoxContainer Orientation="Vertical" Margin="8" HorizontalExpand="True">
        <Label Name="StatusLabel" Text="{Loc 'vaccinator-no-sample'}" />
        <BoxContainer Orientation="Horizontal" Margin="0 6 0 4">
            <Button Name="ScanButton" Access="Public" Text="{Loc 'vaccinator-scan-button'}" Disabled="True" HorizontalExpand="True" />
            <Button Name="EjectButton" Access="Public" Text="{Loc 'vaccinator-eject-button'}" Margin="4 0 0 0" />
        </BoxContainer>
        <ProgressBar Name="ScanProgress" MaxValue="1" Value="0" MinHeight="14" />
        <PanelContainer StyleClasses="LowDivider" Margin="0 6" />
        <BoxContainer Name="ResultsContainer" Orientation="Vertical" />
        <PanelContainer StyleClasses="LowDivider" Margin="0 6" />
        <Label Name="BufferLabel" />
        <BoxContainer Orientation="Horizontal" Margin="0 4 0 0">
            <Button Name="TransferButton" Access="Public" Text="{Loc 'vaccinator-transfer-button'}" Disabled="True" HorizontalExpand="True" />
            <Button Name="CreateVaccineButton" Access="Public" Text="{Loc 'vaccinator-create-button'}" Disabled="True" Margin="4 0 0 0" HorizontalExpand="True" />
        </BoxContainer>
        <Button Name="PrintButton" Access="Public" Text="{Loc 'vaccinator-print-button'}" Disabled="True" Margin="0 4 0 0" HorizontalExpand="True" />
    </BoxContainer>
</DefaultWindow>
