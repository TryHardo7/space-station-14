<surgeryUiParts:OperationDescription
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    xmlns:surgeryUiParts="clr-namespace:Content.Client.SS220.Surgery.UiParts"
    VerticalExpand="True">
    <Control VerticalExpand="True">
        <PanelContainer>
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BackgroundColor="#1B1B1E"/>
            </PanelContainer.PanelOverride>
        </PanelContainer>
        <!-- Kinda overall info to make player feel more confident.
        It should give the right step order and some description for operation -->
        <BoxContainer Orientation="Vertical" VerticalExpand="True">
            <BoxContainer Orientation="Horizontal">
                <TextureRect Name="LockIcon" Stretch="Keep" TexturePath="/Textures/Interface/VerbIcons/lock.svg.192dpi.png"
                    Visible="False" TextureScale="0.25 0.25" SetSize="16 16"/>
                <RichTextLabel Name="Header" Text="{Loc 'operation-description-header'}" HorizontalExpand="True" HorizontalAlignment="Left"/>
            </BoxContainer>
            <BoxContainer Orientation="Vertical" VerticalExpand="True">
                <ScrollContainer Name="ScrollOperationContainer" HScrollEnabled="False"
                    HorizontalExpand="False" VerticalExpand="True" MouseFilter="Pass">
                    <BoxContainer Name="OperationContainer" Orientation="Vertical"
                        HorizontalExpand="False" VerticalExpand="True">
                        <!-- Added by code -->
                    </BoxContainer>
                </ScrollContainer>
            </BoxContainer>
        </BoxContainer>
    </Control>
</surgeryUiParts:OperationDescription>
