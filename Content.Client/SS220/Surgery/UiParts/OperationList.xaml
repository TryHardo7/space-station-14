<surgeryUiParts:OperationList
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    xmlns:surgeryUiParts="clr-namespace:Content.Client.SS220.Surgery.UiParts"
    VerticalExpand="True"
    HorizontalExpand="True">
    <PanelContainer VerticalExpand="True" HorizontalExpand="True">
        <PanelContainer.PanelOverride>
            <gfx:StyleBoxFlat BackgroundColor="#1B1B1E"/>
        </PanelContainer.PanelOverride>
    </PanelContainer>
    <BoxContainer Name="ContentContainer" Orientation="Vertical" VerticalExpand="True" HorizontalExpand="True">
        <RichTextLabel Name="HeaderText" Text="{Loc 'operation-list-header'}"/>
        <ScrollContainer Name="OperationScroll" HScrollEnabled="False"
            HorizontalExpand="True" VerticalExpand="True" MouseFilter="Pass">
            <BoxContainer
                Name="OperationContainer"
                Orientation="Vertical"
                HorizontalExpand="True"
                VerticalExpand="True"
                VerticalAlignment="Top">
                <!--  operations are added here by code  -->
            </BoxContainer>
        </ScrollContainer>
    </BoxContainer>
</surgeryUiParts:OperationList>
